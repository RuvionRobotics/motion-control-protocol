// telemetry_datagram.fbs
// High-frequency robot state telemetry sent from controller to client.
// Conventions:
// - Joint space: 7 values, index 0..6 => j1..j7
// - Temperatures: n values (one per motor), f32::NAN if not available

namespace ruvion.motion;

file_identifier "MOTE";

// ---------- Per-arm telemetry ----------

table ArmTelemetry {
  target_position:   [float];   // 7: commanded q1..q7
  target_velocity:   [float];   // 7: commanded dq1..dq7
  target_torque:     [float];   // 7: commanded torques
  actual_position:   [float];   // 7: measured q1..q7
  actual_velocity:   [float];   // 7: measured dq1..dq7
  actual_torque:     [float];   // 7: measured torques
  motor_temperature:  [float];   // 7: motor winding temperature, NaN = unavailable
  driver_temperature: [float];   // 7: drive/inverter temperature, NaN = unavailable
  fault_codes:       [uint16];  // n: CiA402 error codes per joint
  faulted:           [bool];    // n: per-joint fault flags
  quick_stop_active: [bool];    // n: per-joint quickstop active
  // TCP pose + velocity: optional, omitted when kinematics unavailable
  tcp_actual_position:       [float];  // 3: x, y, z in mm (measured)
  tcp_actual_orientation:    [float];  // 4: w, x, y, z quaternion (measured)
  tcp_actual_linear_vel:     [float];  // 3: vx, vy, vz in mm/s (measured)
  tcp_actual_angular_vel:    [float];  // 3: rx, ry, rz in rad/s (measured)
  tcp_commanded_position:    [float];  // 3: x, y, z in mm (commanded)
  tcp_commanded_orientation: [float];  // 4: w, x, y, z quaternion (commanded)
  tcp_commanded_linear_vel:  [float];  // 3: vx, vy, vz in mm/s (commanded)
  tcp_commanded_angular_vel: [float];  // 3: rx, ry, rz in rad/s (commanded)
}

// ---------- Safety / supervisory state ----------

table SafetyState {
  any_fault:           bool;
  all_op_enabled:      bool;
  quickstop_requested: bool;
  quickstop_active:    bool;
  // Sequence tracking: last command received from client, and which seq is currently being executed
  last_received_seq:   uint64;
  active_seq:          uint64;
  // Control ownership: true if a client currently holds the control token
  has_controller:      bool;
}

// ---------- System state ----------

enum DriveStatus : byte {
  Off = 0,
  SettingUp = 1,
  BusFault = 2,
  DriveFault = 3,
  QuickStop = 4,
  Operational = 5
}

enum ActivityType : byte {
  Idle = 0,
  GravityCalibration = 1,
  FrictionCalibration = 2
}

enum MotionStatus : byte {
  Idle = 0,
  Settling = 1,
  Moving = 2,
  Braking = 3
}

table SystemState {
  drive_status:    DriveStatus;
  activity:        ActivityType;
  activity_step:   uint16;
  activity_total:  uint16;
  motion:          MotionStatus;
  is_impedance:    bool;
}

// ---------- Robot configuration variants ----------

table SingleTelemetry {
  arm: ArmTelemetry (required);
}

table HumanoidTelemetry {
  right: ArmTelemetry (required);
  left:  ArmTelemetry (required);
}

union RobotTelemetryType { SingleTelemetry, HumanoidTelemetry }

// ---------- Envelope ----------

table TelemetryData {
  seq:    uint64;
  safety: SafetyState (required);
  robot:  RobotTelemetryType (required);
  system: SystemState;
}

root_type TelemetryData;
